# ── LLM 配置 ────────────────────────────────────────────────
# 需要 OpenAI-compatible API（项目用 langchain_openai.ChatOpenAI）
# 已测试可用：DeepSeek / OpenAI / 其他兼容服务
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=16000

# ── arXiv 源配置（官方源不可达时切换镜像，可选）─────────────
# 默认用官方源；如需切换取消下面注释即可：
#ARXIV_BASE=https://arxiv.org
#ARXIV_RSS_BASE=https://rss.arxiv.org

# ── 抓取健壮性配置（可选）──────────────────────────────────
#RSS_TIMEOUT=15
#RSS_MAX_RETRIES=3
#RSS_PARALLEL=1
#EPRINT_TIMEOUT=60
#EPRINT_MAX_RETRIES=3
# 两次 e-print 下载之间的最小间隔(秒)，防止深读批量下载被 arXiv 限流
#EPRINT_MIN_INTERVAL=3.0

# ── 礼貌性配置（推荐填写真实邮箱）──────────────────────────
# 写入 User-Agent 与 OpenAlex mailto，进入 polite pool；留空则不带邮箱
#CONTACT_EMAIL=your-email@example.com

# ── OpenAlex 补充数据源（可选，默认关闭）────────────────────
#OPENALEX_ENABLED=0

# ── 输出目录（可选，默认 E:/ArXiv_Polymer_Papers/daily_papers）─
#DAILY_OUTPUT_DIR=E:/ArXiv_Polymer_Papers/daily_papers
